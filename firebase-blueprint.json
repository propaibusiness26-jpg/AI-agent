{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "Represents an active inquirer or business opportunity from Gmail or WhatsApp.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the lead"
        },
        "source": {
          "type": "string",
          "enum": ["gmail", "whatsapp"],
          "description": "Communication channel where lead originated"
        },
        "name": {
          "type": "string",
          "description": "Name of the lead"
        },
        "contact": {
          "type": "string",
          "description": "Email address or phone number of the lead"
        },
        "status": {
          "type": "string",
          "enum": ["new", "replied", "converted", "ignored"],
          "description": "Current status of the lead follow-up"
        },
        "lastMessage": {
          "type": "string",
          "description": "The latest message sent by the inquirer"
        },
        "aiResponse": {
          "type": "string",
          "description": "AI-generated response or draft reply"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when lead was created"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when lead was last updated"
        },
        "ownerId": {
          "type": "string",
          "description": "User ID of the client who owns this lead"
        }
      },
      "required": ["id", "source", "name", "contact", "status", "lastMessage", "createdAt", "updatedAt", "ownerId"]
    },
    "Log": {
      "title": "AutomationLog",
      "description": "Audit log of actions taken by the AI agent.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the log"
        },
        "leadId": {
          "type": "string",
          "description": "Linked lead identifier"
        },
        "contact": {
          "type": "string",
          "description": "Inquirer contact identifier"
        },
        "channel": {
          "type": "string",
          "enum": ["gmail", "whatsapp"],
          "description": "Automation channel"
        },
        "status": {
          "type": "string",
          "enum": ["success", "pending", "failed"],
          "description": "Status of response delivery"
        },
        "message": {
          "type": "string",
          "description": "Content of reply sent or drafted"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the log was created"
        },
        "ownerId": {
          "type": "string",
          "description": "User ID of the client"
        }
      },
      "required": ["id", "leadId", "contact", "channel", "status", "message", "timestamp", "ownerId"]
    },
    "Setting": {
      "title": "AgentSettings",
      "description": "Configurations for response generation and behavior.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "User ID matching their account configuration"
        },
        "companyName": {
          "type": "string",
          "description": "Company or product name"
        },
        "companyDescription": {
          "type": "string",
          "description": "Information about products/services used to train the agent"
        },
        "agentTone": {
          "type": "string",
          "enum": ["professional", "friendly", "persuasive", "direct"],
          "description": "Tone of voice for AI messages"
        },
        "gmailAutomationToggle": {
          "type": "boolean",
          "description": "Whether AI scans and replies to Gmail automatically"
        },
        "whatsappAutomationToggle": {
          "type": "boolean",
          "description": "Whether AI scans and replies to WhatsApp automatically"
        },
        "gmailAutoSend": {
          "type": "boolean",
          "description": "Send response immediately vs saving as draft"
        },
        "whatsappAutoSend": {
          "type": "boolean",
          "description": "Send response immediately vs manual approval"
        },
        "ownerId": {
          "type": "string",
          "description": "User ID of owner"
        }
      },
      "required": ["id", "companyName", "companyDescription", "agentTone", "gmailAutomationToggle", "whatsappAutomationToggle", "gmailAutoSend", "whatsappAutoSend", "ownerId"]
    }
  },
  "firestore": {
    "leads/{leadId}": {
      "schema": "Lead",
      "description": "Active business leads"
    },
    "logs/{logId}": {
      "schema": "Log",
      "description": "Agent activity ledger"
    },
    "settings/{settingId}": {
      "schema": "Setting",
      "description": "Client settings"
    }
  }
}
